# פרטי גישה למאגר decisions.court.gov.il — עבור ההורדה היומית (fetch_daily.py).
# העתיקו קובץ זה לקובץ בשם .env (באותה תיקייה) ומלאו את הפרטים.
# קובץ .env מוחרג מ-git ולעולם לא נשמר במאגר הקוד.

DECISIONS_USER=User106G
DECISIONS_PASSWORD=הכניסו-כאן-את-הסיסמה

# אופציונלי:
# DECISIONS_URL=https://decisions.court.gov.il/
# DECISIONS_DAYS=0   # 0 = כל התיקיות הקיימות בשרת; 2 = רק היומיים האחרונים
# DECISIONS_DOMAIN=IDC

# אחסון חיצוני של קבצי המקור (PDF/Word) ב-Cloudflare R2 — אופציונלי.
# בלי זה, האתר עדיין עובד רגיל (כולל חיפוש טקסט מלא), רק בלי קישור
# להורדת הקובץ המקורי.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=giluy-naot-docs
# R2_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev
