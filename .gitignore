# אינדקס החיפוש (data/index.db) כן נשמר ב-git: ההרצה היומית דוחפת אותו
# אוטומטית, וזה מה שמעדכן את האתר הציבורי (Streamlit Cloud) בלי להעלות
# את קבצי ה-PDF/Word הגולמיים. שאר קבצי ה-DB (למשל גיבויים זמניים) מוחרגים.
data/*.db-journal
data/*.db-wal
data/*.db-shm

# פסקי דין (נתונים גולמיים, כולל ההורדות היומיות לתת-תיקיות) — לא נשמרים ב-git
documents/**
!documents/.gitkeep

# יומני הרצה (מקומיים)
daily_log.txt
full_run_log.txt
ingest_log.txt
r2_upload_log.txt

# מעקב מקומי אחרי קבצים שכבר הועלו ל-R2 (לא רלוונטי מחוץ למחשב הזה)
data/.r2_uploaded.txt

# הגדרות מקומיות של Claude Code (לא חלק מהפרויקט)
.claude/

# פייתון
__pycache__/
*.pyc
.venv/
venv/
.env

# סודות (מפתחות API) — לעולם לא נשמרים ב-git
.streamlit/secrets.toml

# מערכת
.DS_Store
Thumbs.db
