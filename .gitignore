# אינדקס החיפוש (data/index.db) חדל להישמר ב-git: הקובץ חרג מ-100MB
# (מגבלת הגודל הקשיחה של GitHub לקובץ בודד). הוא מתארח ב-R2 במקום
# (zot.storage.upload_index/sync_index) — האתר מוריד אותו משם בהפעלה.
data/index.db
data/index.db.bak*
data/.*.synced_etag
data/*.db-journal
data/*.db-wal
data/*.db-shm

# פסקי דין (נתונים גולמיים, כולל ההורדות היומיות לתת-תיקיות) — לא נשמרים ב-git
documents/**
!documents/.gitkeep

# ארכיון בית המשפט העליון (fetch_supreme.py) — נתונים גולמיים, לא נשמרים ב-git
documents_supreme/**

# יומני הרצה (מקומיים)
*_log.txt
*_log2.txt
*_log3.txt
*_err.txt
*_err2.txt
*_err3.txt
daily_log.txt
full_run_log.txt
ingest_log.txt
r2_upload_log.txt
supreme_download_log.txt
ingest_log*.txt
summarize_full_log.txt
summary_test_log.txt
page_scan_log.txt
page_count_analysis.json
supreme_failed_slices*.log

# מעקב מקומי אחרי קבצים שכבר הועלו ל-R2 (לא רלוונטי מחוץ למחשב הזה)
data/.r2_uploaded.txt
data/.r2_uploaded_supreme.txt

# הגדרות מקומיות של Claude Code (לא חלק מהפרויקט), למעט סוכנים משותפים והרשאות פרויקט
.claude/*
!.claude/agents/
!.claude/settings.json

# פייתון
__pycache__/
*.pyc
.venv/
venv/
.env

# סודות (מפתחות API) — לעולם לא נשמרים ב-git
.streamlit/secrets.toml

# מערכת
.DS_Store
Thumbs.db
