# העתיקו קובץ זה ל-.env.local למילוי מקומי (הקובץ .env.local לא נשמר בגיט)

# מפתח ה-API של Anthropic (מתחיל ב-sk-ant-)
ANTHROPIC_API_KEY=

# מזהה הסוכן שיצרתם ב-Anthropic (מתחיל ב-agent_)
AGENT_ID=

# מזהה סביבת הריצה (מתחיל ב-env_)
ENVIRONMENT_ID=

# הסיסמה שתגן על האתר — בחרו סיסמה חזקה
ACCESS_PASSWORD=
